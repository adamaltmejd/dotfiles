# Whitelist approach: ignore everything, then explicitly track what we want
*

# Root files
!.gitignore
!README.md
!CLAUDE.md
!bootstrap.sh
!setup.sh

# Zsh configuration
!zsh/
!zsh/**

# Git+Github configuration
!git/
!git/**
!gh/
!gh/**

# SSH configuration
!ssh/
!ssh/**

# R configuration (explicit files only; XDG-aware packages write here too)
!r/
!r/Rprofile
!r/Renviron
!r/lintr

# Radian (R console)
!radian/
!radian/**

# Ansible
!ansible/
!ansible/**

# Ghostty
!ghostty/
!ghostty/**

# AI agents (Claude Code, Codex CLI, shared skills)
!agents/
!agents/**

# macOS helper files
!macos/
!macos/**

# Setup internals and docs
!setup/
!setup/**
!docs/
!docs/**

# Ignore generated/local files within tracked dirs
zsh/plugins.zsh
zsh/.zcompdump*
zsh/conf.d/local.zsh
git/config.local
gh/hosts.yml

# Common junk
.DS_Store
*.swp
*~

# Ignore local/sensitive files
*.local
